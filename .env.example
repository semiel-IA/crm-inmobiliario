# URL pública del proyecto Supabase. Dashboard → Project Settings → Data API → Project URL.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Clave anónima (pública, segura de exponer al navegador). Dashboard → Project Settings →
# API Keys → anon public (o "publishable" en proyectos nuevos).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Clave service_role: secreta, bypassa Row Level Security. Dashboard → Project Settings →
# API Keys → service_role (o "secret"). NUNCA exponer al cliente ni commitear.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cadena de conexión a Postgres. Dashboard → Project Settings → Database → Connection string →
# URI. Reemplaza [DB_PASSWORD_PENDIENTE] por la contraseña real de la base de datos (Project
# Settings → Database → Reset database password si no la tienes) y URL-encódala si tiene
# caracteres especiales (ej. `#` → `%23`).
#
# Conexión directa (funciona si esta red soporta IPv6, que es lo único que exponen los
# proyectos nuevos de Supabase en `db.<ref>.supabase.co`):
DATABASE_URL=postgresql://postgres:[DB_PASSWORD_PENDIENTE]@db.your-project-ref.supabase.co:5432/postgres
#
# Alternativa vía session pooler (IPv4, útil si la conexión directa no resuelve/conecta;
# nota el usuario `postgres.<ref>` y el host regional `aws-<0|1>-<region>.pooler.supabase.com`):
# DATABASE_URL=postgresql://postgres.your-project-ref:[DB_PASSWORD_PENDIENTE]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres
